{
  "name": "cs2-demotracer-desktop",
  "private": true,
  "version": "0.8.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "check": "npm run check:crosshair && tsc --noEmit --pretty false && tsc --noEmit --pretty false -p tsconfig.node.json",
    "check:crosshair": "node scripts/check-crosshair.mjs",
    "build": "tsc --noEmit --pretty false && tsc --noEmit --pretty false -p tsconfig.node.json && vite build",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build --no-bundle"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.1",
    "csgo-sharecode": "5.0.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.11.4",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "typescript": "6.0.3",
    "vite": "8.0.16"
  }
}
