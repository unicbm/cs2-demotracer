{
  "identity": "steam",
  "allow_partial": true,
  "playoff": false,
  "chat_auto": true,
  "handoff": {
    "mode": "death_contact_c4",
    "scope": "slot",
    "threat_360": true,
    "threat_360_range": 420,
    "threat_360_los": true,
    // "round" keeps the final viewmodel and left/right-hand desired latch until
    // the round boundary after handoff or natural replay completion. Replay
    // input, movement, buy plans, and weapon locks are still released at once.
    // Use "release" to restore the pre-replay viewmodel immediately instead.
    "viewmodel_continuity": "round"
  },
  "fidelity": {
    "preset": "default",
    // Safe by default: BotHider publishes demo crosshairs from the server and
    // never writes human client configuration. Set false to disable alignment.
    "crosshair": true
  },
  "match": {
    "preset": "off"
  },
  "cosmetics": {
    "preset": "off",
    "agents": false,
    "preserve_native": false
  }
}
